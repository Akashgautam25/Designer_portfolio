# ── FRONTEND (set these in Vercel / Netlify dashboard) ────────────────────

# Your deployed backend URL — e.g. https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# WebSocket URL — same host without /api
NEXT_PUBLIC_WS_URL=https://api.yourdomain.com

# NextAuth (if using NextAuth features)
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=   # generate: openssl rand -hex 32

# Neon DB (only if Next.js API routes query DB directly)
DATABASE_URL=
