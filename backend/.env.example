# ── BACKEND (set these in Railway / Render / Fly.io dashboard) ────────────

DATABASE_URL=postgresql://...

# Redis (set false to skip — JWT-only mode works without Redis)
REDIS_URL=redis://...
REDIS_ENABLED=true

# Generate: node -e "require('crypto').randomBytes(48).then(b=>console.log(b.toString('hex')))"
JWT_SECRET=

# Admin account
ADMIN_EMAIL=admin@yourdomain.com
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# Comma-separated list of your frontend domains
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Server
PORT=4000
NODE_ENV=production

# AWS S3 (optional — for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
